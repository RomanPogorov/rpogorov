---
/**
 * Base layout. Loads the legacy CSS bundle (extracted 1:1 from the original
 * index.html), fonts, marked.js, and the R3F importmap so any page in the
 * /app/ Astro build inherits the same visual + JS environment as the legacy
 * main page.
 */
interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  bodyTheme?: 'green' | 'cyan' | 'mono' | 'ember';
}

const {
  title = 'ROMAN POGOROV / GRID',
  description,
  bodyClass = '',
  bodyTheme = 'green',
} = Astro.props;

const importMapJson = `{
  "imports": {
    "react": "https://esm.sh/react@18.3.1",
    "react/jsx-runtime": "https://esm.sh/react@18.3.1/jsx-runtime",
    "react-dom": "https://esm.sh/react-dom@18.3.1",
    "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
    "scheduler": "https://esm.sh/scheduler@0.23.2",
    "three": "https://esm.sh/three@0.160.1",
    "@react-three/fiber": "https://esm.sh/@react-three/fiber@8.17.10?external=react,react-dom,three,scheduler",
    "@react-three/drei": "https://esm.sh/@react-three/drei@9.117.0?external=react,react-dom,three,@react-three/fiber",
    "postprocessing": "https://esm.sh/postprocessing@6.36.0?external=three",
    "@react-three/postprocessing": "https://esm.sh/@react-three/postprocessing@2.16.3?external=react,react-dom,three,@react-three/fiber,postprocessing"
  }
}`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700;800&family=Orbitron:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js" defer is:inline></script>
    <script type="importmap" is:inline set:html={importMapJson}></script>
    <script src="https://unpkg.com/@babel/standalone@7.25.7/babel.min.js" defer is:inline></script>
  </head>
  <body class:list={[bodyClass]} data-theme={bodyTheme}>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/legacy.css';
  @import '../styles/tokens.css';
  @import '../styles/content.css';

  /* Inside the cs0X overlay we mount the MDX body in a `.cnt-body` wrapper
     so content.css typography (h2/h3/p/ul/blockquote/code/pre/table)
     applies to the markdown prose. Legacy .am-* / .cp-* / .case-page
     classes still style the rich-component islands. */
  .case-page .cnt-body {
    max-width: var(--measure-content);
    margin: 0 auto;
  }

  /* Reset content.css ol-counter / list-bullet treatment for legacy
     navigation lists — they're flex-row interactive components, not
     prose lists. Without this, .cp-timeline gets a stray "01 / 02 …"
     left-padded counter that pushes each tab right and overlaps the
     real button content. */
  .cnt-body .cp-timeline-list {
    max-width: none;
  }
  .cnt-body .cp-timeline-list,
  .cnt-body .cp-timeline-list li,
  .cnt-body .am-deeplinks,
  .cnt-body .am-deeplinks > a,
  .cnt-body .am-plans,
  .cnt-body .am-plans > div,
  .cnt-body .am-gallery,
  .cnt-body .am-gallery > figure {
    padding-left: 0;
    margin-bottom: 0;
  }
  .cnt-body .cp-timeline-list li::before,
  .cnt-body .cp-timeline-list::before,
  .cnt-body .am-deeplinks > a::before,
  .cnt-body .am-plans > div::before,
  .cnt-body .am-gallery > figure::before {
    content: none;
  }
  /* The cp-timeline sticky breakout escapes the .cnt-body column to span
     full case-page width, which is the legacy intent. Make sure it can
     reach the scrollable .case-page top edge without the cnt-body's
     own max-width clamping its negative margins. */
  .case-page .cnt-body > .cp-timeline {
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    width: 100vw;
    max-width: 100vw;
  }

  /* Default content tokens (dark theme) — case components reference these
     vars; without defaults they fall through to initial / white-on-white in
     cp-light. Mirrors content.css's body:not(.theme-bright) block but lives
     at :root scope so it applies on /app/ where body has data-theme=green. */
  :root {
    --text-strong: #ffffff;
    --text-base: rgba(255, 255, 255, 0.86);
    --text-muted: rgba(232, 255, 240, 0.62);
    --ink-strong: #ffffff;
    --ink-muted: rgba(232, 255, 240, 0.62);
    --surface-card: rgba(255, 255, 255, 0.03);
    --surface-frame: #16191e;
    --border-soft: rgba(var(--acc-rgb), 0.18);
    --border-card: rgba(var(--acc-rgb), 0.22);
    --measure-content: 720px;
    --measure-body: 720px;
  }

  /* Accent scale — derived from the case's --acc so a block can paint with
     5+ distinct shades and still flex with one accent change. The scale is
     declared on .case-page so each case's inline `--acc` recomputes it.
     - tint-* mix accent into transparent (work on any bg, dark or light)
     - mix-* mix accent into white (solid pastels for bright theme)
     - shade-* mix accent into black (darker variants for hover / borders)
     Components reading --acc-tint-soft, --acc-shade-strong, etc. recolor
     end-to-end when accent flips. */
  .case-page {
    --acc-tint-soft:   color-mix(in srgb, var(--acc) 5%,  transparent);
    --acc-tint-medium: color-mix(in srgb, var(--acc) 12%, transparent);
    --acc-tint-strong: color-mix(in srgb, var(--acc) 22%, transparent);
    --acc-line:        color-mix(in srgb, var(--acc) 32%, transparent);
    --acc-mix-soft:    color-mix(in srgb, var(--acc) 8%,  white);
    --acc-mix-medium:  color-mix(in srgb, var(--acc) 18%, white);
    --acc-shade-soft:  color-mix(in srgb, var(--acc), black 12%);
    --acc-shade-strong:color-mix(in srgb, var(--acc), black 22%);
  }

  /* Bright variant — flips every token a case-component reads, so PainCard,
     ImpactStrip, IterCard, Pillar, MetaGrid, Figure render on white with
     dark text and visible card surfaces. The accent (--acc / --acc-rgb)
     is set inline per-case via index.astro's accent resolver, so each
     case can have its own brand color. We intentionally don't set --acc
     here — the inline style wins by specificity, and falls through to
     :root's cyber cyan if a case forgets to declare one. */
  .case-page.cp-light {
    --text-strong: #0b1018;
    --text-base: #2a313e;
    --text-muted: #5b6372;
    --ink-strong: #0b1018;
    --ink-muted: #5b6372;
    --surface-card: #ffffff;
    --surface-frame: #f4f6fa;
    --border-soft: #e2e6ec;
    --border-card: #d8dde5;
  }
  /* Visible card surfaces on white — without these the var(--surface-card)
     #ffffff blends into the page bg and the card vanishes. */
  .case-page.cp-light .pain-card,
  .case-page.cp-light .impact-strip > article,
  .case-page.cp-light .iter-card,
  .case-page.cp-light .pillar,
  .case-page.cp-light .meta-grid > article {
    box-shadow: 0 1px 2px rgba(11, 16, 24, 0.04);
  }
  .case-page.cp-light .iter-card {
    background: rgba(var(--acc-rgb), 0.04);
    border-color: rgba(var(--acc-rgb), 0.20);
  }

  /* Legacy .dc-* islands (Mobile / Wide / Row2 / Row3 / Callout / Quote /
     Tradeoff / etc.) are styled by legacy.css with dark frames. The
     legacy bright variant lives at .dc-page.dc-bright .dc-*, which never
     matches our .case-page.cp-light wrapper. Mirror just the rules that
     touch user-visible chrome — strip dark frames around media, rebase
     callouts/quotes/tradeoffs to white surfaces, recolor captions. */
  .case-page.cp-light .dc-figure {
    background: transparent;
    border: 0;
    padding: 0;
    margin-top: 32px;
    margin-bottom: 56px;
  }
  .case-page.cp-light .dc-figure img,
  .case-page.cp-light .dc-figure video {
    max-height: 700px;
    max-width: 100%;
    width: auto;
    margin: 0 auto;
    display: block;
  }
  .case-page.cp-light .dc-figure figcaption {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    color: #6b7280;
    padding: 16px 0 0;
    text-align: center;
  }
  .case-page.cp-light .dc-grid-2,
  .case-page.cp-light .dc-grid-3 {
    margin: 32px 0 56px;
  }
  .case-page.cp-light .dc-grid-2 .dc-figure,
  .case-page.cp-light .dc-grid-3 .dc-figure {
    margin: 0;
  }
  .case-page.cp-light .dc-callout {
    background: rgba(var(--acc-rgb), 0.05);
    border-left-color: var(--acc);
    color: var(--text-base);
  }
  .case-page.cp-light .dc-callout strong { color: var(--text-strong); }
  .case-page.cp-light .dc-quote {
    color: var(--text-base);
    border-left-color: rgba(var(--acc-rgb), 0.5);
  }
  .case-page.cp-light .dc-tradeoff {
    background: #ffffff;
    border-color: var(--border-card);
    color: var(--text-base);
    box-shadow: 0 1px 2px rgba(11, 16, 24, 0.04);
  }
  .case-page.cp-light .dc-tradeoff .label { color: var(--acc); }
  .case-page.cp-light .dc-tradeoff p { color: var(--text-base); }
  .case-page.cp-light .dc-iter {
    background: rgba(var(--acc-rgb), 0.04);
    border: 1px solid rgba(var(--acc-rgb), 0.16);
    border-radius: 12px;
    padding: 20px 24px;
    margin: 14px 0;
    color: var(--text-base);
  }
  .case-page.cp-light .dc-iter .label { color: var(--acc); }
  .case-page.cp-light .dc-iter .body { color: var(--text-base); }
  .case-page.cp-light .dc-iter .body strong { color: var(--text-strong); }
  .case-page.cp-light .dc-stat-row { background: transparent; border-color: var(--border-card); }
  .case-page.cp-light .dc-stat-row .cell { color: var(--text-base); border-color: var(--border-soft); }
  .case-page.cp-light .dc-stat-row .lbl { color: var(--text-muted); }
  .case-page.cp-light .dc-stat-row .val { color: var(--text-strong); }
  .case-page.cp-light .am-media-frame,
  .case-page.cp-light .am-media-stub {
    background: transparent;
    border: 0;
  }
  /* Prose typography in MDX body — mirror content.css bright values. */
  .case-page.cp-light .cnt-body :where(p, li) { color: var(--text-base); }
  .case-page.cp-light .cnt-body :where(h1, h2, h3, h4) { color: var(--text-strong); }
  .case-page.cp-light .cnt-body strong { color: var(--text-strong); }
  .case-page.cp-light .cnt-body em { color: var(--acc); font-style: normal; font-weight: 500; }
  .case-page.cp-light .cnt-body :where(blockquote) {
    color: var(--text-base);
    border-left-color: var(--acc);
    background: rgba(var(--acc-rgb), 0.05);
  }
  .case-page.cp-light .cnt-body :where(hr) {
    border-color: var(--border-soft);
  }

  /* Global theme toggle — rendered at body level (sibling of .case-page,
     not child) so position:fixed escapes the .case-page's translateY()
     containing block. JS finds the open .case-page on click. */
  .cp-theme-toggle-global {
    position: fixed;
    bottom: 22px;
    right: 24px;
    z-index: 60;
    width: 40px;
    height: 40px;
    display: none;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(5, 5, 5, 0.6);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }
  body.case-open .cp-theme-toggle-global[data-theme-target] { display: inline-flex; }
  .cp-theme-toggle-global:hover { border-color: rgba(var(--acc-rgb), 0.7); }
  .cp-theme-toggle-global.is-light {
    border-color: rgba(11, 16, 24, 0.16);
    background: rgba(255, 255, 255, 0.92);
    color: #0b1018;
  }
  .cp-theme-toggle-global.is-light:hover { border-color: var(--acc); }

  /* ============ SCREENCAST mode — curved holographic display ============ */
  .ss-toggle {
    position: fixed;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 90;
    appearance: none;
    border: 1px solid rgba(var(--ui-acc-rgb), 0.45);
    background: rgba(5, 8, 10, 0.6);
    color: var(--ui-acc);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    letter-spacing: 0.4em;
    padding: 8px 18px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.18s, color 0.18s, background 0.18s;
  }
  .ss-toggle:hover {
    border-color: var(--ui-acc);
    color: #fff;
    background: rgba(var(--ui-acc-rgb), 0.1);
  }
  body.screencast-on .ss-toggle { display: none; }

  /* Hide all green chrome when screencast is on */
  body.screencast-on .hud,
  body.screencast-on .hud-left-articles,
  body.screencast-on .hud-right,
  body.screencast-on .panel,
  body.screencast-on .prompt,
  body.screencast-on .ctl-fab,
  body.screencast-on .perf-hud,
  body.screencast-on .stage,
  body.screencast-on .grid,
  body.screencast-on .horizon,
  body.screencast-on .scanlines,
  body.screencast-on .noise,
  body.screencast-on .vignette,
  body.screencast-on [class*="layer-"],
  body.screencast-on .r3f-bg,
  body.screencast-on .showcase,
  body.screencast-on .showcase-cue,
  body.screencast-on .ctl-fab-eyebrow {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }

  /* The screencast stage — full-bleed dark scene */
  .screencast-stage {
    position: fixed;
    inset: 0;
    z-index: 80;
    background:
      radial-gradient(ellipse 70% 50% at 50% 60%, rgba(20, 30, 50, 0.6), transparent 70%),
      linear-gradient(180deg, #02060c 0%, #050810 60%, #080c14 100%);
    overflow: hidden;
    color: #c9d8ec;
    font-family: 'JetBrains Mono', monospace;
    perspective: 2400px;
    perspective-origin: 50% 55%;
  }
  .screencast-stage[hidden] { display: none; }

  /* Corner HUD widgets — futuristic info plaques like the reference. */
  .ss-corner {
    position: absolute;
    z-index: 5;
    padding: 14px 18px;
    border: 1px solid rgba(120, 180, 240, 0.28);
    background: linear-gradient(180deg, rgba(8, 18, 32, 0.55), rgba(8, 18, 32, 0.25));
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #b8d4f0;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.5;
    text-shadow: 0 0 6px rgba(120, 180, 240, 0.5);
    pointer-events: none;
  }
  .ss-corner-tl { top: 24px; left: 24px; min-width: 180px; }
  .ss-corner-tr { top: 24px; right: 24px; text-align: right; min-width: 140px; }
  .ss-corner-eyebrow { color: #7fbbff; font-weight: 700; }
  .ss-corner-temp {
    font-size: 1.75rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #d8eaff;
    text-shadow: 0 0 12px rgba(120, 180, 240, 0.7);
  }
  .ss-corner-clock {
    font-size: 1.625rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: #d8eaff;
    text-shadow: 0 0 12px rgba(120, 180, 240, 0.7);
  }
  .ss-corner-meta { font-size: 0.625rem; opacity: 0.7; margin-top: 4px; }
  .ss-corner-data { font-size: 0.625rem; opacity: 0.55; margin-top: 2px; }

  /* The curved display itself.
     Real curve: we wrap an iframe in a wide container, then use border-radius
     with separate horizontal/vertical radii (50% / 6%) to clip into a wide
     curved-edge shape, plus a CSS mask with a radial fade so the left/right
     edges feather into darkness like a panoramic OLED. The whole assembly
     sits inside a perspective container with a slight rotateX so it tilts
     toward the viewer. The iframe inside is flat and fully interactive —
     scroll, click, anchor links all work. */
  .ss-display {
    position: absolute;
    top: 50%;
    left: 50%;
    transform-style: preserve-3d;
    transform: translate(-50%, -50%) rotateX(-3deg);
    width: min(86vw, 1500px);
    aspect-ratio: 21 / 9;
    max-height: 78vh;
  }
  .ss-display-glow {
    position: absolute;
    inset: -40px;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 48% at 50% 50%, rgba(120, 200, 255, 0.16), transparent 70%);
    filter: blur(20px);
    z-index: 0;
  }
  .ss-display-frame {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50% / 7%;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 1px rgba(180, 220, 255, 0.35),
      inset 0 0 80px rgba(80, 160, 240, 0.18),
      0 0 60px rgba(80, 160, 240, 0.25),
      0 0 120px rgba(40, 90, 180, 0.18);
    background: #050810;
    /* Side fade — the left/right edges fade into darkness, selling the curve.
       The radial mask is wider than tall so the falloff is mostly horizontal. */
    -webkit-mask-image: radial-gradient(ellipse 78% 100% at 50% 50%, #000 70%, transparent 100%);
    mask-image: radial-gradient(ellipse 78% 100% at 50% 50%, #000 70%, transparent 100%);
  }
  .ss-display-inner {
    width: 100%;
    height: 100%;
    /* Sub-tilt the inner content for a parallax sliver effect */
    transform: translateZ(0);
  }
  .ss-iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #0a0e16;
    color-scheme: light;
  }
  /* Top + bottom glowing bezels — thin lines that follow the curve. */
  .ss-display-bezel {
    position: absolute;
    left: -2%;
    right: -2%;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(140, 200, 255, 0.0) 8%,
      rgba(140, 200, 255, 0.85) 50%,
      rgba(140, 200, 255, 0.0) 92%,
      transparent 100%);
    box-shadow: 0 0 12px rgba(140, 200, 255, 0.6);
    pointer-events: none;
    z-index: 3;
    border-radius: 50% / 100%;
  }
  .ss-display-bezel-top { top: -1px; }
  .ss-display-bezel-bottom { bottom: -1px; }

  /* Exit button — sits in bottom-right of the stage. */
  .ss-exit {
    position: absolute;
    bottom: 28px;
    right: 28px;
    z-index: 5;
    appearance: none;
    border: 1px solid rgba(140, 200, 255, 0.4);
    background: rgba(5, 10, 18, 0.55);
    color: #b8d4f0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    letter-spacing: 0.32em;
    padding: 8px 14px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.18s, color 0.18s, background 0.18s;
  }
  .ss-exit:hover {
    border-color: #b8d4f0;
    color: #fff;
    background: rgba(140, 200, 255, 0.1);
  }
  .ss-exit-arrow {
    display: inline-block;
    transform: rotate(180deg);
    font-size: 0.875rem;
  }

  @media (max-width: 760px) {
    .ss-display { width: 96vw; aspect-ratio: 16 / 10; }
    .ss-corner { font-size: 0.5625rem; padding: 10px 12px; }
    .ss-corner-tl, .ss-corner-tr { top: 14px; min-width: 0; }
    .ss-corner-tl { left: 14px; }
    .ss-corner-tr { right: 14px; }
    .ss-corner-temp, .ss-corner-clock { font-size: 1.125rem; }
  }

</style>
