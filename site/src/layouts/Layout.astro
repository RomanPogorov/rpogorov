---
/**
 * Base layout. Loads the legacy CSS bundle (extracted 1:1 from the original
 * index.html), fonts, marked.js, and the R3F importmap so any page in the
 * /app/ Astro build inherits the same visual + JS environment as the legacy
 * main page.
 */
interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  bodyTheme?: 'green' | 'cyan' | 'mono' | 'ember';
}

const {
  title = 'ROMAN POGOROV / GRID',
  description,
  bodyClass = '',
  bodyTheme = 'green',
} = Astro.props;

const importMapJson = `{
  "imports": {
    "react": "https://esm.sh/react@18.3.1",
    "react/jsx-runtime": "https://esm.sh/react@18.3.1/jsx-runtime",
    "react-dom": "https://esm.sh/react-dom@18.3.1",
    "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
    "scheduler": "https://esm.sh/scheduler@0.23.2",
    "three": "https://esm.sh/three@0.160.1",
    "@react-three/fiber": "https://esm.sh/@react-three/fiber@8.17.10?external=react,react-dom,three,scheduler",
    "@react-three/drei": "https://esm.sh/@react-three/drei@9.117.0?external=react,react-dom,three,@react-three/fiber",
    "postprocessing": "https://esm.sh/postprocessing@6.36.0?external=three",
    "@react-three/postprocessing": "https://esm.sh/@react-three/postprocessing@2.16.3?external=react,react-dom,three,@react-three/fiber,postprocessing"
  }
}`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700;800&family=Orbitron:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js" defer is:inline></script>
    <script type="importmap" is:inline set:html={importMapJson}></script>
    <script src="https://unpkg.com/@babel/standalone@7.25.7/babel.min.js" defer is:inline></script>
  </head>
  <body class:list={[bodyClass]} data-theme={bodyTheme}>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/legacy.css';
  @import '../styles/tokens.css';
  @import '../styles/content.css';

  /* Inside the cs0X overlay we mount the MDX body in a `.cnt-body` wrapper
     so content.css typography (h2/h3/p/ul/blockquote/code/pre/table)
     applies to the markdown prose. Legacy .am-* / .cp-* / .case-page
     classes still style the rich-component islands. */
  .case-page .cnt-body {
    max-width: var(--measure-content);
    margin: 0 auto;
  }

  /* Reset content.css ol-counter / list-bullet treatment for legacy
     navigation lists — they're flex-row interactive components, not
     prose lists. Without this, .cp-timeline gets a stray "01 / 02 …"
     left-padded counter that pushes each tab right and overlaps the
     real button content. */
  .cnt-body .cp-timeline-list {
    max-width: none;
  }
  .cnt-body .cp-timeline-list,
  .cnt-body .cp-timeline-list li,
  .cnt-body .am-deeplinks,
  .cnt-body .am-deeplinks > a,
  .cnt-body .am-plans,
  .cnt-body .am-plans > div,
  .cnt-body .am-gallery,
  .cnt-body .am-gallery > figure {
    padding-left: 0;
    margin-bottom: 0;
  }
  .cnt-body .cp-timeline-list li::before,
  .cnt-body .cp-timeline-list::before,
  .cnt-body .am-deeplinks > a::before,
  .cnt-body .am-plans > div::before,
  .cnt-body .am-gallery > figure::before {
    content: none;
  }
  /* The cp-timeline sticky breakout escapes the .cnt-body column to span
     full case-page width, which is the legacy intent. Make sure it can
     reach the scrollable .case-page top edge without the cnt-body's
     own max-width clamping its negative margins. */
  .case-page .cnt-body > .cp-timeline {
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    width: 100vw;
    max-width: 100vw;
  }

  /* Theme toggle button on sub-case overlays — bottom-right so it
     doesn't fight the cp-close (top-right back-to-showcase button). */
  .cp-theme-toggle {
    position: fixed;
    bottom: 22px;
    right: 24px;
    z-index: 55;
    width: 40px;
    height: 40px;
    display: none;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(5, 5, 5, 0.6);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }
  body.case-open .case-page.open .cp-theme-toggle { display: inline-flex; }
  .cp-theme-toggle:hover { border-color: rgba(var(--acc-rgb), 0.7); }
  .case-page.cp-light .cp-theme-toggle {
    border-color: rgba(0, 0, 0, 0.18);
    background: rgba(255, 255, 255, 0.85);
    color: #0b1018;
  }
  .case-page.cp-light .cp-theme-toggle:hover {
    border-color: var(--acc);
  }

</style>
