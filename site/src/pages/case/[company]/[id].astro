---
/**
 * /rpogorov-dev/app/case/{company}/{id}/ — deep case detail.
 *
 * Renders one MDX case via the shared CaseHeader component (same header
 * we use for the overlay version) so the standalone page and the in-app
 * overlay look identical. Inline JS wires the breadcrumb click hooks
 * (data-cp-crumb="main"/"showcase", data-cp-crumb-company) to standalone
 * navigation: Main/Showcase → /app/, Company → /app/#case/csXX.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CaseHeader from '@components/case/CaseHeader.astro';

export const getStaticPaths = (async () => {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { company: entry.data.company, id: entry.data.deeplink },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

// Per-case accent override (matches the overlay path in pages/index.astro).
const ACCENT_PRESETS: Record<string, { hex: string; rgb: string }> = {
  green: { hex: '#059669', rgb: '5, 150, 105' },
  blue:  { hex: '#1d4ed8', rgb: '29, 78, 216' },
  red:   { hex: '#dc2626', rgb: '220, 38, 38' },
  cyan:  { hex: '#00e5ff', rgb: '0, 229, 255' },
};
const accent = typeof data.accent === 'string'
  ? (ACCENT_PRESETS[data.accent as keyof typeof ACCENT_PRESETS] ?? ACCENT_PRESETS.green)
  : data.accent;
const accentStyle = `--acc: ${accent.hex}; --acc-rgb: ${accent.rgb};`;
const themeClass = data.theme === 'bright' ? 'cp-light' : '';
---

<Layout
  title={`${data.title} — ${data.companyLabel}`}
  description={data.desc}
  bodyTheme="green"
>
  <section class:list={['case-page', 'is-standalone', themeClass]} style={accentStyle} data-case-page={data.deeplink}>
    <CaseHeader
      companyLabel={data.companyLabel}
      companyId={data.company}
      currentLabel={data.title}
      metaItems={[data.companyLabel, ...(data.metric ? [data.metric] : [])]}
      title={data.title}
      desc={data.desc}
      tags={data.tags}
      impact={data.impact}
    >
      <article class="cnt-body">
        <Content />
      </article>
    </CaseHeader>
  </section>
</Layout>

<script is:inline>
  // Standalone-page click hooks for the shared CaseHeader breadcrumbs.
  // Main / Showcase → home page; Company → home page with a hash that the
  // legacy router will pick up to open the company overlay; ESC button →
  // also home.
  (() => {
    const base = '/rpogorov-dev/app/';
    document.addEventListener('click', (e) => {
      const el = e.target.closest('button[data-cp-crumb], button[data-cp-crumb-company], button[data-cp-close]');
      if (!el) return;
      e.preventDefault();
      if (el.dataset.cpCrumb === 'main' || el.dataset.cpCrumb === 'showcase') {
        location.href = base;
        return;
      }
      if (el.dataset.cpCrumbCompany) {
        location.href = base + '#case/' + el.dataset.cpCrumbCompany;
        return;
      }
      if (el.hasAttribute('data-cp-close')) {
        location.href = base;
        return;
      }
    });
    // ESC key also returns to the app root.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') location.href = base;
    });
  })();
</script>

<style>
  /* Standalone page wrapper — gives the shared CaseHeader's sticky bar
     a real document to scroll inside, since outside the overlay there's
     no fixed-position .case-page container. */
  .case-page.is-standalone {
    position: relative;
    inset: auto;
    background: #050505;
    color: #fff;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    min-height: 100vh;
  }
  .case-page.is-standalone.cp-light { background: #f6f8fb; color: #0f1419; }
</style>
