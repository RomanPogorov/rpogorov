---
/**
 * /rpogorov-dev/app/case/{company}/{id}/ — deep case detail.
 *
 * Renders one MDX case from the `cases` collection inside ContentLayout.
 * Hero block exposes title, description, tags, ImpactStrip + MetaGrid (the
 * standalone components), then the MDX body in `.cnt-body` so all markdown
 * elements pick up content typography.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';
import ImpactStrip from '@components/case/ImpactStrip.astro';
import MetaGrid from '@components/case/MetaGrid.astro';

export const getStaticPaths = (async () => {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { company: entry.data.company, id: entry.data.deeplink },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const baseUrl = `${import.meta.env.BASE_URL}`.replace(/\/$/, '');
---

<ContentLayout
  title={`${data.title} — ${data.companyLabel}`}
  description={data.desc}
  theme={data.theme}
>
  <main class="page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={`${baseUrl}/`}>Showcase</a>
      <span class="sep">/</span>
      <span class="company-crumb">{data.companyLabel}</span>
      <span class="sep">/</span>
      <span class="current">{data.title}</span>
    </nav>

    <header class="hero">
      <div class="hero-meta">
        <span class="no">{data.no ?? data.companyLabel}</span>
        {data.metric && <span class="metric">{data.metric}</span>}
      </div>
      <h1 class="title">{data.title}</h1>
      <ul class="tags">
        {data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
      <p class="desc">{data.desc}</p>
    </header>

    {data.impact.length > 0 && <ImpactStrip cells={data.impact} />}
    {data.meta.length > 0 && <MetaGrid items={data.meta} />}

    <article class="cnt-body">
      <Content />
    </article>
  </main>
</ContentLayout>

<style>
  .page {
    max-width: var(--measure-content);
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-24);
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: var(--space-10);
  }
  .crumbs a, .crumbs .company-crumb {
    color: var(--acc);
    text-decoration: none;
    border-bottom: none;
  }
  .crumbs a:hover { text-decoration: underline; }
  .sep { opacity: 0.5; }
  .current {
    color: var(--ink-strong);
    max-width: 60ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero { margin-bottom: var(--space-12); }
  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-4);
  }
  .no {
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    font-weight: 600;
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--acc);
  }
  .metric {
    font-family: var(--font-mono);
    font-size: var(--type-sm);
    font-weight: 600;
    color: var(--acc);
  }
  .title {
    font-family: var(--font-display);
    font-size: var(--type-h1);
    font-weight: 800;
    line-height: var(--line-tight);
    letter-spacing: var(--track-display);
    color: var(--ink-strong);
    margin: 0 0 var(--space-5);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: var(--type-2xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--acc);
    border: 1px solid rgba(var(--acc-rgb), 0.32);
    padding: var(--space-1) var(--space-3);
    background: rgba(var(--acc-rgb), 0.05);
    border-radius: var(--radius-sm);
  }
  .desc {
    font-size: var(--type-lg);
    line-height: 1.55;
    color: var(--ink);
    max-width: var(--measure-narrow);
    margin: 0;
  }
</style>
