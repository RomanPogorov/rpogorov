---
/**
 * /rpogorov-dev/app/company/cs02/ — Health Samurai full case page.
 *
 * Same pattern as cs01 — legacy `<section class="case-page cp-hs">` body
 * lives at src/legacy-cs02.html and injects via Fragment set:html. Layout
 * loads legacy.css so the HS-specific Gantt timeline + cp-hs theme
 * overrides apply.
 */
import Layout from '@layouts/Layout.astro';
import legacyCs02 from '../../legacy-cs02.html?raw';
---

<Layout
  title="Health Samurai — Roman Pogorov"
  description="Aidbox + five healthcare products: cross-product design system, Figma ↔ code via Code Connect, AI-assisted component generation through a Claude skill."
  bodyTheme="green"
>
  <main class="cp-standalone">
    <a class="cp-standalone-back" href="../" aria-label="Back to showcase">↑ back to cases</a>
    <Fragment set:html={legacyCs02} />
  </main>
</Layout>

<style is:global>
  body { overflow-x: hidden; overflow-y: auto; }
  .cp-standalone { position: relative; min-height: 100vh; }
  .cp-standalone .case-page {
    position: relative !important;
    transform: none !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: auto !important;
    height: auto !important;
    inset: auto !important;
  }
  .cp-standalone .cp-close { display: none; }
  .cp-standalone-back {
    position: fixed;
    top: 24px;
    right: 32px;
    z-index: 100;
    color: var(--acc);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid rgba(var(--acc-rgb), 0.4);
    padding: 8px 14px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    transition: background 200ms, border-color 200ms;
  }
  .cp-standalone-back:hover {
    background: rgba(var(--acc-rgb), 0.12);
    border-color: var(--acc);
  }
</style>
