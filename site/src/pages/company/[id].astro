---
/**
 * /rpogorov-dev/app/company/{cs0X}/ — top-level company case page.
 *
 * Uses CaseLayout (tokens + content typography + legacy.css) so MDX prose
 * gets the article-reader treatment AND any rich components imported in
 * MDX (Metric, Timeline, HeroShot, BeforeAfter) style with the legacy
 * .am-metric / .am-tl-* / .cp-hero-shot / .am-ba-* rules.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import CaseLayout from '@layouts/CaseLayout.astro';

export const getStaticPaths = (async () => {
  const companies = await getCollection('companies');
  return companies.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const baseUrl = `${import.meta.env.BASE_URL}`.replace(/\/$/, '');
---

<CaseLayout title={`${data.name} — ${data.title}`} description={data.desc}>
  <a class="cs-back" href={`${baseUrl}/cases/`} aria-label="Back to cases">↑ back to cases</a>

  <main class="page">
    <header class="hero">
      <div class="hero-meta">
        <span class="no">{data.id.toUpperCase().replace('CS', 'CS/')}</span>
        <span class="dot">·</span>
        <span>{data.name}</span>
        <span class="dot">·</span>
        <span>{data.role}</span>
        <span class="dot">·</span>
        <span>{data.year}</span>
      </div>
      <h1 class="title" set:html={data.title} />
      {data.desc && <p class="lead">{data.desc}</p>}
      <ul class="tags">
        {data.tags.map((t) => <li>{t}</li>)}
      </ul>
    </header>

    <article class="cnt-body">
      <Content />
    </article>
  </main>
</CaseLayout>

<style is:global>
  body { overflow-x: hidden; }

  .cs-back {
    position: fixed;
    top: 24px;
    right: 32px;
    z-index: 100;
    color: var(--acc);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid rgba(var(--acc-rgb), 0.4);
    padding: 8px 14px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    transition: background 200ms, border-color 200ms;
  }
  .cs-back:hover {
    background: rgba(var(--acc-rgb), 0.12);
    border-color: var(--acc);
  }
</style>

<style>
  .page {
    max-width: var(--measure-content);
    margin: 0 auto;
    padding: var(--space-16) var(--space-8) var(--space-24);
  }
  .hero { margin-bottom: var(--space-12); }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--type-2xs);
    font-weight: 600;
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: var(--space-5);
  }
  .hero-meta .no { color: var(--acc); }
  .hero-meta .dot { opacity: 0.5; }
  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: #fff;
    margin: 0 0 var(--space-5);
  }
  .title :global(em) {
    color: var(--acc);
    font-style: normal;
    text-shadow:
      0 0 18px rgba(var(--acc-rgb), 0.45),
      0 0 36px rgba(var(--acc-rgb), 0.25);
  }
  .lead {
    font-size: var(--type-lg);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
    max-width: var(--measure-narrow);
    margin: 0 0 var(--space-6);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: var(--type-2xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--acc);
    border: 1px solid rgba(var(--acc-rgb), 0.32);
    padding: var(--space-1) var(--space-3);
    background: rgba(var(--acc-rgb), 0.05);
    border-radius: var(--radius-sm);
  }
</style>
