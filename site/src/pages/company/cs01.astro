---
/**
 * /rpogorov-dev/app/company/cs01/ — Americor full case page.
 *
 * Legacy `<section class="case-page" id="case-page-cs01">` body extracted
 * to src/legacy-cs01.html and injected via Fragment set:html. Layout.astro
 * loads legacy.css globally so all the bespoke markup (Gantt timeline,
 * before/after sliders, am-metric trend lines, cp-hero-shot board) styles
 * exactly as in the legacy main page.
 */
import Layout from '@layouts/Layout.astro';
import legacyCs01 from '../../legacy-cs01.html?raw';
---

<Layout
  title="Americor — Roman Pogorov"
  description="Two-year fintech rebuild for an American debt-relief company: web + iOS + Android, multi-brand, IPO mode. Phase-aware UX, ground-up design system."
  bodyTheme="green"
>
  <main class="cp-standalone">
    <a class="cp-standalone-back" href="../" aria-label="Back to showcase">↑ back to cases</a>
    <Fragment set:html={legacyCs01} />
  </main>
</Layout>

<style is:global>
  /* Standalone case-page wrapper: legacy case-page is `position:fixed`
     for the main-page overlay. Strip the fixed positioning and make it a
     regular flow document so it works as its own URL. */
  body { overflow-x: hidden; overflow-y: auto; }
  .cp-standalone { position: relative; min-height: 100vh; }
  .cp-standalone .case-page {
    position: relative !important;
    transform: none !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: auto !important;
    height: auto !important;
    inset: auto !important;
  }
  /* Hide the in-overlay close button — we have our own back link */
  .cp-standalone .cp-close { display: none; }
  .cp-standalone-back {
    position: fixed;
    top: 24px;
    right: 32px;
    z-index: 100;
    color: var(--acc);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid rgba(var(--acc-rgb), 0.4);
    padding: 8px 14px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    transition: background 200ms, border-color 200ms;
  }
  .cp-standalone-back:hover {
    background: rgba(var(--acc-rgb), 0.12);
    border-color: var(--acc);
  }
</style>
