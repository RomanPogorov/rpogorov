---
/**
 * /rpogorov-dev/app/article/{id}/ — article reader.
 *
 * Renders one MDX/MD article from the `articles` content collection inside
 * ContentLayout (tokens + typography only — no legacy.css). The body markup
 * is wrapped in `.cnt-body` so the content.css :where() rules style every
 * element regardless of how the markdown nests.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';

export const getStaticPaths = (async () => {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const baseUrl = `${import.meta.env.BASE_URL}`.replace(/\/$/, '');
const fmtDate = data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<ContentLayout title={`${data.title} — Roman Pogorov`} description={data.description} theme="dark">
  <main class="page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={`${baseUrl}/`}>Showcase</a>
      <span class="sep">/</span>
      <a href={`${baseUrl}/articles/`}>Articles</a>
      <span class="sep">/</span>
      <span class="current">{data.title}</span>
    </nav>

    <header class="hero">
      <div class="meta">
        <time datetime={data.date.toISOString()}>{fmtDate}</time>
        {data.readingTime && <span class="rt">{data.readingTime}</span>}
        <span class="author">{data.author}</span>
      </div>
      <h1 class="title">{data.title}</h1>
      <p class="lead">{data.description}</p>
      <ul class="tags">
        {data.tags.map((t) => <li>{t}</li>)}
      </ul>
    </header>

    <article class="cnt-body">
      <Content />
    </article>
  </main>
</ContentLayout>

<style>
  .page {
    max-width: var(--measure-content);
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-24);
  }
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: var(--space-10);
  }
  .crumbs a {
    color: var(--acc);
    text-decoration: none;
    border-bottom: none;
  }
  .crumbs a:hover { text-decoration: underline; }
  .sep { opacity: 0.5; }
  .current {
    color: var(--ink-strong);
    max-width: 60ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero {
    margin-bottom: var(--space-12);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--type-2xs);
    font-weight: 600;
    letter-spacing: var(--track-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: var(--space-5);
  }
  .meta time { color: var(--acc); }
  .meta .author {
    margin-left: auto;
    color: var(--ink);
  }
  .title {
    font-family: var(--font-display);
    font-size: var(--type-h1);
    font-weight: 800;
    line-height: var(--line-tight);
    letter-spacing: var(--track-display);
    color: var(--ink-strong);
    text-transform: uppercase;
    margin: 0 0 var(--space-5);
  }
  .lead {
    font-family: var(--font-body);
    font-size: var(--type-lg);
    line-height: 1.55;
    color: var(--ink);
    max-width: var(--measure-narrow);
    margin: 0 0 var(--space-6);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: var(--type-2xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--acc);
    border: 1px solid rgba(var(--acc-rgb), 0.32);
    padding: 3px var(--space-2);
    border-radius: var(--radius-sm);
    background: rgba(var(--acc-rgb), 0.05);
  }
</style>
