---
/**
 * /rpogorov-dev/app/ — main entry. Legacy main page rebuilt in Astro.
 * MDX-driven pieces:
 *
 * 1. Showcase carousel cards (5 cs0X entries) — server-rendered from
 *    src/content/companies/*.mdx at build time, replacing the hardcoded
 *    cards block in legacy-body.html.
 *
 * 2. cs01 (Americor) deep overlay — `<section class="case-page" data-
 *    case-page="cs01">` rendered here in JSX from src/content/companies/
 *    cs01.mdx. Triggered by `data-open-case="cs01"` on the carousel card
 *    via legacy __cp.open().
 *
 * 3. Four Americor sub-case overlays — `<section class="case-page" data-
 *    case-page="{deeplink}">` per entry in src/content/cases/. Triggered
 *    by hash `#case/cs01/{deeplink}` (legacy router) → __dc.open() which
 *    we override below to proxy to __cp.open() so the section-based
 *    overlay shows.
 *
 * Body content for cs01 + 4 sub-cases lives only in MDX. legacy-body.html
 * still ships its DEEP_CASES bodies, but they're not rendered anywhere
 * because our __dc proxy targets the Astro-rendered overlays.
 */
import Layout from '@layouts/Layout.astro';
import Lightbox from '@components/case-rich/Lightbox.astro';
import legacyBodyRaw from '../legacy-body.html?raw';
import { getCollection, render } from 'astro:content';

const companies = (await getCollection('companies')).sort(
  (a, b) => a.data.order - b.data.order
);
const subCases = (await getCollection('cases')).sort(
  (a, b) => a.data.order - b.data.order
);
const rightPanel = (await getCollection('rightPanel')).sort(
  (a, b) => a.data.order - b.data.order
);
const tasks = rightPanel.filter((e) => e.data.kind === 'pain');
const strengths = rightPanel.filter((e) => e.data.kind === 'strength');
const releases = rightPanel.filter((e) => e.data.kind === 'release');

const cs01 = companies.find((c) => c.id === 'cs01');
const cs01Render = cs01 ? await render(cs01) : null;
const Cs01Content = cs01Render?.Content ?? null;

const cs02 = companies.find((c) => c.id === 'cs02');
const cs02Render = cs02 ? await render(cs02) : null;
const Cs02Content = cs02Render?.Content ?? null;

const subRendered = await Promise.all(
  subCases.map(async (entry) => {
    const r = await render(entry);
    return { entry, Content: r.Content };
  })
);

const baseUrl = `${import.meta.env.BASE_URL}`.replace(/\/$/, '');

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function withEm(s: string): string {
  return escapeHtml(s)
    .replace(/&lt;em&gt;/g, '<em>')
    .replace(/&lt;\/em&gt;/g, '</em>');
}

function caseLabel(_id: string, idx: number): string {
  return `CS/${String(idx + 1).padStart(2, '0')}`;
}

// cs0X cards with a deep overlay wired up. cs01 → MDX overlay below;
// cs02 → legacy inline overlay still in legacy-body.html.
const OVERLAY_ID: Record<string, string> = {
  cs01: 'cs01',
  cs02: 'cs02',
};

const cardsHtml = companies
  .map((c, i) => {
    const d = c.data;
    const title = d.showcaseTitle ?? d.title;
    const desc = d.showcaseDesc ?? d.desc;
    const tags = d.showcaseTags ?? d.tags;
    const meta = d.showcaseMeta ?? `${d.name} · ${d.role} · ${d.year}`;
    const thumb = d.thumb ?? '';
    const overlayId = OVERLAY_ID[c.id];

    const mediaCls = overlayId ? 'case-media is-openable' : 'case-media';
    const mediaTrigger = overlayId
      ? ` data-open-case="${overlayId}" role="button" tabindex="0" aria-label="Open ${escapeHtml(d.name)} case study"`
      : '';
    const openCue = overlayId
      ? `<div class="case-media-open-cue" aria-hidden="true"><span class="arrow">↓</span><span>Open case</span></div>`
      : '';
    const openBtn = overlayId
      ? `<button class="case-open-btn" data-open-case="${overlayId}" type="button" aria-label="Open full case"><span class="open-arrow" aria-hidden="true">↓</span><span>Open case</span></button>`
      : '';

    return `<article class="case" data-case="${c.id}">
      <div class="${mediaCls}"${mediaTrigger}>
        <img src="${escapeHtml(thumb)}" alt="${escapeHtml(d.name)}">
        ${openCue}
      </div>
      <div class="case-body">
        <div class="case-head">
          <span class="case-no">${caseLabel(c.id, i)}</span>
          <span class="case-role">${escapeHtml(d.role)}</span>
        </div>
        <h3 class="case-title">${withEm(title)}</h3>
        <p class="case-desc">${withEm(desc)}</p>
        <ul class="case-tags">
          ${tags.map((t) => `<li>${escapeHtml(t)}</li>`).join('')}
        </ul>
        <div class="case-meta">${escapeHtml(meta)}</div>
        ${openBtn}
      </div>
    </article>`;
  })
  .join('\n');

const tasksHtml = tasks
  .map(
    (t) =>
      `<li class="task-item" data-id="${escapeHtml(t.data.id)}" tabindex="0"><span class="task-text">${escapeHtml(t.data.lead ?? '')}</span></li>`
  )
  .join('');

const agentsHtml = strengths
  .map((s) => {
    const d = s.data;
    const name = d.short?.name ?? d.title.split(' ')[0];
    const tagShort = d.short?.summary ?? '';
    const meta = d.short?.date ?? '';
    return `<li class="agent-item" data-id="${escapeHtml(d.id)}">
        <span class="agent-dot"></span>
        <div class="agent-body">
          <div class="agent-name">${escapeHtml(name)} <span class="agent-tag">${escapeHtml(tagShort)}</span></div>
          <div class="agent-task" data-task>${escapeHtml(d.lead ?? '')}</div>
          <div class="agent-meta" data-meta>${escapeHtml(meta)}</div>
        </div>
      </li>`;
  })
  .join('');

const releasesHtml = releases
  .map((r) => {
    const d = r.data;
    const sh = d.short ?? {};
    return `<li class="release-item" data-id="${escapeHtml(d.id)}" tabindex="0">
        <div class="release-meta-row">
          <span class="release-version">${escapeHtml(sh.role ?? '')}</span>
          <span class="release-date">${escapeHtml(sh.date ?? '')}</span>
        </div>
        <div class="release-name">${escapeHtml(sh.name ?? d.title)}</div>
        <div class="release-summary">${escapeHtml(sh.summary ?? '')}</div>
      </li>`;
  })
  .join('');

// Build DETAIL dictionary keyed by id — same shape legacy JS expects.
function renderDetailHtml(d: any): string {
  const stats = (d.stats ?? [])
    .map((s: any) => `<div class="dw-stat"><div class="dw-stat-k">${s.k}</div><div class="dw-stat-v">${s.v}</div></div>`)
    .join('');
  const sections = (d.sections ?? [])
    .map((s: any) => {
      const items = s.items.map((it: string) => `<li>${it}</li>`).join('');
      return `<div class="dw-section"><h3>${s.h}</h3><ul class="dw-list">${items}</ul></div>`;
    })
    .join('');
  const cta = d.cta
    ? `<div class="dw-cta"><a class="dw-cta-link" data-open-showcase="${d.cta.openShowcase}">${d.cta.label}</a></div>`
    : '';
  return `<div class="dw-stats">${stats}</div>${sections}${cta}`;
}

const detailDict = Object.fromEntries(
  rightPanel.map((entry) => [
    entry.data.id,
    {
      tag: entry.data.tag,
      title: entry.data.title,
      html: renderDetailHtml(entry.data),
    },
  ])
);

let legacyBody = legacyBodyRaw.replace(
  /<div class="cases" id="cases">[\s\S]*?<\/div>(?=\s*\n\s*<!--\s*By Cases view)/,
  `<div class="cases" id="cases">\n${cardsHtml}\n            </div>`
);

// Replace right-panel lists with content-collection-rendered versions.
legacyBody = legacyBody
  .replace(
    /<ul class="tasks-list" id="tasks-list">[\s\S]*?<\/ul>/,
    `<ul class="tasks-list" id="tasks-list">${tasksHtml}</ul>`
  )
  .replace(
    /<ul class="agents-list" id="agents-list">[\s\S]*?<\/ul>/,
    `<ul class="agents-list" id="agents-list">${agentsHtml}</ul>`
  )
  .replace(
    /<ul class="releases-list" id="releases-list">[\s\S]*?<\/ul>/,
    `<ul class="releases-list" id="releases-list">${releasesHtml}</ul>`
  );

// Replace inline DETAIL = {...} dictionary with a window-injected lookup
// so legacy detail-window JS reads our content-collection data instead.
legacyBody = legacyBody.replace(
  /const DETAIL = \{[\s\S]*?\n\s+\};/,
  'const DETAIL = window.__RIGHT_PANEL_DETAIL || {};'
);

const [legacyBefore, afterAmericor] = legacyBody.split('<!-- AMERICOR_OVERLAY_MARKER -->');
const [legacyMid, legacyAfter] = afterAmericor.split('<!-- HS_OVERLAY_MARKER -->');

const cs01Data = cs01?.data;
const cs02Data = cs02?.data;
---

<Layout title="ROMAN POGOROV / GRID" bodyTheme="green" bodyClass="pre-gate">
  <script is:inline set:html={`window.__RIGHT_PANEL_DETAIL = ${JSON.stringify(detailDict)};`}></script>
  <Fragment set:html={legacyBefore} />

  {Cs01Content && cs01Data && (
    <section class="case-page" id="case-page-cs01" data-case-page="cs01" aria-label={`${cs01Data.name} case study`}>
      <button class="cp-close" data-cp-close type="button" aria-label="Back to showcase">
        <span class="cp-close-arrow" aria-hidden="true">↑</span>
        <span>back to showcase</span>
      </button>
      <div class="cp-inner">
        <header class="cp-hero">
          <div class="cp-meta">
            <span class="cp-meta-no">CS/01</span>
            <span class="cp-meta-divider"></span>
            <span>{cs01Data.name}</span>
            <span class="cp-meta-divider"></span>
            <span>{cs01Data.role}</span>
            <span class="cp-meta-divider"></span>
            <span>{cs01Data.year}</span>
          </div>
          <h1 class="cp-title" set:html={cs01Data.title} />
          <p class="cp-sub">{cs01Data.desc}</p>
        </header>
        <article class="cnt-body">
          <Cs01Content />
        </article>
      </div>
    </section>
  )}

  <Fragment set:html={legacyMid} />

  {Cs02Content && cs02Data && (
    <section class="case-page cp-hs" id="case-page-cs02" data-case-page="cs02" aria-label={`${cs02Data.name} case study`}>
      <button class="cp-close" data-cp-close type="button" aria-label="Back to showcase">
        <span class="cp-close-arrow" aria-hidden="true">↑</span>
        <span>back to showcase</span>
      </button>
      <header class="hs-hero">
        <div class="hs-eyebrow">{cs02Data.name} · {cs02Data.year} · 12 deep dives</div>
        <h1 class="hs-h1" set:html={cs02Data.title} />
        <p class="hs-lead">{cs02Data.desc}</p>
      </header>
      <div class="cnt-body">
        <Cs02Content />
      </div>
    </section>
  )}

  {
    subRendered.map(({ entry, Content }) => {
      const d = entry.data;
      const themeClass = d.theme === 'bright' ? 'cp-light' : '';
      // Resolve per-case accent → inline CSS vars on .case-page so PainCard,
      // IterCard, dc-tags, dc-callout, dc-quote, dc-tradeoff and every other
      // var(--acc) consumer recolors automatically.
      const ACCENT_PRESETS = {
        green: { hex: '#059669', rgb: '5, 150, 105' },
        blue:  { hex: '#1d4ed8', rgb: '29, 78, 216' },
        red:   { hex: '#dc2626', rgb: '220, 38, 38' },
        cyan:  { hex: '#00e5ff', rgb: '0, 229, 255' },
      };
      const accent = typeof d.accent === 'string'
        ? ACCENT_PRESETS[d.accent] ?? ACCENT_PRESETS.green
        : d.accent;
      const accentStyle = `--acc: ${accent.hex}; --acc-rgb: ${accent.rgb};`;
      return (
        <section
          class:list={['case-page', themeClass]}
          id={`case-page-${d.deeplink}`}
          data-case-page={d.deeplink}
          data-theme={d.theme}
          data-accent={typeof d.accent === 'string' ? d.accent : 'custom'}
          style={accentStyle}
          aria-label={`${d.title} case study`}
        >
          <div class="cp-crumbs-bar">
            <nav class="dc-crumbs" aria-label="Breadcrumbs">
              <button type="button" class="dc-crumb" data-cp-crumb="showcase">Showcase</button>
              <span class="dc-crumb-sep">‹</span>
              <button type="button" class="dc-crumb" data-cp-crumb-company={d.company}>{d.companyLabel}</button>
              <span class="dc-crumb-sep">‹</span>
              <span class="dc-crumb-current">{d.deeplink.toUpperCase()}</span>
            </nav>
            <button type="button" class="dc-close" data-cp-close aria-label="Close case">ESC</button>
          </div>
          <div class="cp-inner dc-inner">
            <div class="dc-meta-row">
              <span class="dc-meta-company">{d.companyLabel}</span>
              {d.metric && <span class="dc-meta-metric">{d.metric}</span>}
            </div>
            <h1 class="dc-title">{d.title}</h1>
            {d.tags && (
              <ul class="dc-tags">
                {d.tags.map((t) => <li>{t}</li>)}
              </ul>
            )}
            {d.desc && <p class="dc-desc">{d.desc}</p>}
            {d.impact && d.impact.length > 0 && (
              <div class="dc-impact">
                {d.impact.map((it) => (
                  <div class="dc-impact-cell">
                    <div class="num">{it.num}</div>
                    <div class="lbl">{it.lbl}</div>
                  </div>
                ))}
              </div>
            )}
            <article class="cnt-body">
              <Content />
            </article>
          </div>
        </section>
      );
    })
  }

  <Fragment set:html={legacyAfter} />

  <button
    class="cp-theme-toggle-global"
    data-cp-theme-toggle-global
    type="button"
    aria-label="Toggle case theme"
  >◐</button>

  <script is:inline>
    // Hero text mode tracker — three states based on signal slider:
    //   norm > 0.15        → normal (Claude Runner + portfolio slogan)
    //   0.02 < norm ≤ 0.15 → letter-glitch loop on every hero element
    //   norm ≤ 0.02        → final swap to "Man with no ego" copy
    (() => {
      function init() {
        const $meta = document.querySelector('.meta-top span:not(.dot)');
        const $name = document.getElementById('prompt-roles');
        const $hero = document.querySelector('.role-hero');
        const $slogan = document.querySelector('.slogan');
        const $cta = document.querySelector('.cta-text');
        if (!$hero) { setTimeout(init, 200); return; }
        const NORMAL = {
          meta: $meta?.textContent ?? 'Roman Pogorov Portfolio 2026',
          name: $name?.textContent ?? 'Designer',
          hero: $hero?.textContent ?? 'Claude Runner',
          slogan: $slogan?.innerHTML ?? '',
          cta: $cta?.textContent ?? 'more information',
        };
        const EGO = {
          meta: 'silent mode · no ego · 2026',
          name: 'Stranger',
          hero: 'Man with no ego',
          slogan: 'no titles. no claims. <em>just presence.</em> <span class="slogan-end">listening over speaking. less is enough.</span>',
          cta: 'sit with it',
        };
        const GLITCH_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%&*+=<>/\\';
        function mutate(text, rate) {
          return text.split('').map((ch) => {
            if (ch === ' ' || ch === '·') return ch;
            return Math.random() < rate ? GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)] : ch;
          }).join('');
        }
        // Walk slogan text nodes (not innerHTML) so we glitch letters
        // without destroying <em>/<span> structure. Re-snapshotted whenever
        // innerHTML changes (setNormal/setEgo) since refs would go stale.
        let sloganNodes = [];
        function snapshotSlogan() {
          sloganNodes = [];
          if (!$slogan) return;
          const w = document.createTreeWalker($slogan, NodeFilter.SHOW_TEXT);
          let n;
          while ((n = w.nextNode())) sloganNodes.push({ node: n, original: n.nodeValue });
        }
        snapshotSlogan();
        function mutateSlogan(rate) {
          for (const { node, original } of sloganNodes) {
            node.nodeValue = mutate(original, rate);
          }
        }
        let state = 'normal';
        let timer = null;
        function setNormal() {
          if ($meta) $meta.textContent = NORMAL.meta;
          if ($name) $name.textContent = NORMAL.name;
          if ($hero) $hero.textContent = NORMAL.hero;
          if ($slogan) { $slogan.innerHTML = NORMAL.slogan; snapshotSlogan(); }
          if ($cta) $cta.textContent = NORMAL.cta;
        }
        function setEgo() {
          if ($meta) $meta.textContent = EGO.meta;
          if ($name) $name.textContent = EGO.name;
          if ($hero) $hero.textContent = EGO.hero;
          if ($slogan) { $slogan.innerHTML = EGO.slogan; snapshotSlogan(); }
          if ($cta) $cta.textContent = EGO.cta;
        }
        function startGlitch() {
          stopGlitch();
          timer = setInterval(() => {
            const rate = 0.12;
            if ($meta) $meta.textContent = mutate(NORMAL.meta, rate);
            if ($name) $name.textContent = mutate(NORMAL.name, rate);
            if ($hero) $hero.textContent = mutate(NORMAL.hero, rate);
            if ($cta) $cta.textContent = mutate(NORMAL.cta, rate);
            mutateSlogan(rate);
          }, 90);
        }
        function stopGlitch() {
          if (timer) { clearInterval(timer); timer = null; }
        }
        document.addEventListener('signal:change', (e) => {
          const norm = e.detail;
          let next;
          if (norm > 0.15) next = 'normal';
          else if (norm > 0.02) next = 'glitching';
          else next = 'ego';
          if (next === state) return;
          state = next;
          stopGlitch();
          if (next === 'normal') setNormal();
          else if (next === 'ego') setEgo();
          else if (next === 'glitching') startGlitch();
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        init();
      }
    })();
  </script>

  <script is:inline>
    // Global theme toggle — single button at body level (so position:fixed
     // escapes the .case-page transform containing block). Tracks which
     // .case-page is currently open and toggles its .cp-light class. Hides
     // when no theme-capable case is active (e.g., cs01 Americor stays dark).
    (() => {
      const btn = document.querySelector('[data-cp-theme-toggle-global]');
      if (!btn) return;

      function activeCase() {
        return document.querySelector('.case-page.open');
      }
      function syncBtn() {
        const cp = activeCase();
        const supports = !!(cp && cp.dataset.theme); // sub-cases set data-theme; cs01 overlay doesn't
        if (supports) {
          btn.setAttribute('data-theme-target', cp.dataset.casePage || cp.id || '1');
          btn.classList.toggle('is-light', cp.classList.contains('cp-light'));
        } else {
          btn.removeAttribute('data-theme-target');
          btn.classList.remove('is-light');
        }
      }

      btn.addEventListener('click', () => {
        const cp = activeCase();
        if (!cp || !cp.dataset.theme) return;
        cp.classList.toggle('cp-light');
        btn.classList.toggle('is-light', cp.classList.contains('cp-light'));
      });

      // Re-evaluate whenever a case opens/closes. Body's .case-open class +
      // each .case-page's .open class change via legacy __cp.open/close, so
      // a MutationObserver on body covers both.
      const obs = new MutationObserver(syncBtn);
      obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });
      document.querySelectorAll('.case-page').forEach((cp) => {
        obs.observe(cp, { attributes: true, attributeFilter: ['class'] });
      });
      // Initial sync after legacy JS finishes hash routing.
      setTimeout(syncBtn, 100);
      setTimeout(syncBtn, 800);
    })();
  </script>

  <script is:inline>
    // Override legacy __dc.open / __dc.close to proxy to __cp so the
    // section-based MDX overlays we render above receive the open/close
    // calls instead of the legacy DEEP_CASES dc-page mechanism. Runs on
    // load so __cp / __dc are both defined by the time we redefine.
    window.addEventListener('load', () => {
      if (!window.__cp) return;
      const dcOpen = (id, opts) => window.__cp.open(id, opts);
      const dcClose = (opts) => window.__cp.close(opts);
      window.__dc = { open: dcOpen, close: dcClose, current: () => null };
      // Wire am-deeplinks (in cs01 MDX) — anchor href="#case/cs01/{slug}"
      // doesn't trigger __dc.open by itself; the legacy hash router
      // listens to popstate and on load. Pushing the hash on click
      // triggers it.
      document.querySelectorAll('a.am-deeplink[href^="#case/"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const m = a.getAttribute('href').match(/^#case\/cs0\d+\/(.+)$/);
          if (m && window.__cp) {
            history.pushState(null, '', a.getAttribute('href'));
            window.__cp.open(m[1]);
          }
        });
      });
      // Wire crumb-company button — closes sub-case and opens parent company case.
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-cp-crumb-company]');
        if (!btn) return;
        const company = btn.dataset.cpCrumbCompany;
        if (!company || !window.__cp) return;
        history.pushState(null, '', `#case/${company}`);
        window.__cp.open(company);
      });
    });
  </script>

  <script is:inline>
    // Sub-case hash router — takes precedence over the legacy DEEP_CASES
    // syncFromHash (which fires on a 80ms timeout after page load and
    // opens the legacy .dc-page bright overlay) and the legacy router
    // (which calls __cp.open on the COMPANY id, scrolling to a sub
    // anchor that doesn't exist in our Astro layout).
    //
    // For URLs like #case/cs01/offer-acceptance we now (1) force-close
    // the legacy dc-page if it opened, (2) close any wrong case-page,
    // (3) open the .case-page[data-case-page=offer-acceptance] sub
    // overlay. Runs after both legacy routers settle.
    (() => {
      function syncSub() {
        const m = location.hash.match(/^#case\/cs0\d+\/([\w-]+)/);
        if (!m) return;
        const sub = m[1];
        // Only intercept if a sub-case overlay actually exists for this id.
        const subPage = document.querySelector(`.case-page[data-case-page="${sub}"]`);
        if (!subPage) return;
        // Force-close the legacy dc-page (may have opened via syncFromHash).
        document.body.classList.remove('dc-open');
        const dc = document.getElementById('dc-page');
        if (dc) dc.classList.remove('dc-open');
        // Close any other case-page that legacy router 2 opened (cs01 etc.).
        document.querySelectorAll('.case-page.open').forEach((cp) => {
          if (cp.dataset.casePage !== sub) cp.classList.remove('open');
        });
        // Open the right sub-case if not already open.
        if (!subPage.classList.contains('open') && window.__cp?.open) {
          window.__cp.open(sub, { silent: true });
        }
        document.body.classList.add('case-open');
      }
      // Run AFTER both legacy routers (~80ms each) have fired.
      window.addEventListener('load', () => setTimeout(syncSub, 200));
      window.addEventListener('hashchange', syncSub);
      window.addEventListener('popstate', syncSub);
    })();
  </script>

  <Lightbox />
</Layout>
