---
/**
 * /rpogorov-dev/app/ — main entry. Rebuilds the legacy index.html body 1:1
 * inside the Astro layout: same markup, same CSS (loaded globally from
 * legacy.css), same inline scripts. The page is meant to be embedded in the
 * outer legacy index.html via iframe in the slide-in showcase area, but it
 * also stands on its own under /app/.
 *
 * Body markup lives at src/legacy-body.html and is injected as raw HTML so
 * Astro's parser doesn't have to interpret 8.8k lines of legacy markup +
 * inline scripts. Inline scripts execute as normal in the browser because
 * set:html lands literally in the served HTML.
 */
import Layout from '@layouts/Layout.astro';
import legacyBody from '../legacy-body.html?raw';
---

<Layout title="ROMAN POGOROV / GRID" bodyTheme="green" bodyClass="pre-gate">
  <Fragment set:html={legacyBody} />
</Layout>
