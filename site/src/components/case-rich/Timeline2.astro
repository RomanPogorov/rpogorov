---
/**
 * Timeline2 — second-pass roadmap. Cleaner than Timeline.astro: one bar
 * per project (active + part-time merged via internal gradient), labels
 * live inside the bar, no kind-legend chrome. Same s/e semantics: s/e
 * are fractional column-line indices over `quarters`.
 *
 * Data shape:
 *   <Timeline2
 *     stamp="// timeline · Dec 2024 → Q2 2026"
 *     quarters={['Q4 24', ..., 'Q2 26']}
 *     nowIdx={6}
 *     streams={[
 *       { sub: '01', name: 'Онбординг и аудит', bars: [
 *         { s: 1.73, e: 2.23, activeUntil: 2.23, label: 'Аудит', duration: '1.5 мес', title: '...' },
 *       ]},
 *       …
 *     ]}
 *   />
 */
interface T2Bar {
  s: number;
  e: number;
  /** Position on the timeline where the active phase ends. Defaults to e
   *  (no part-time tail). The bar gradient stays solid up to this point
   *  and fades from there to e. */
  activeUntil?: number;
  /** Kind of work — drives the bar visual.
   *   primary — Roman led this end-to-end (solid accent gradient)
   *   pair    — paired with another designer (hatched accent)
   *   side    — side / supporting project (grey-neutral) */
  kind?: 'primary' | 'pair' | 'side';
  label: string;
  duration?: string;
  title?: string;
  /** Panel-only overrides — same pattern as Timeline.astro. */
  panelTitle?: string;
  panelDuration?: string;
}
interface T2Stream {
  sub: string;
  name: string;
  bars: T2Bar[];
}
interface Props {
  stamp?: string;
  quarters: string[];
  nowIdx?: number;
  streams: T2Stream[];
}
const { stamp, quarters, nowIdx, streams } = Astro.props;
const cols = quarters.length;
---

<div class="cp-fullbleed t2-bleed">
  <div class="t2-frame">
    <div class="t2-headstrip">
      {stamp && <div class="t2-stamp" set:html={stamp} />}
      <div class="t2-legend">
        <span class="t2-legend-item"><i class="t2-sw t2-sw--primary"></i> Основное</span>
        <span class="t2-legend-item"><i class="t2-sw t2-sw--pair"></i> В паре с другими дизайнерами</span>
        <span class="t2-legend-item"><i class="t2-sw t2-sw--side"></i> Сайд-проект / поддержка</span>
      </div>
    </div>

    <div class="t2-grid">
      <div class="t2-row t2-row--head">
        <div class="t2-label" aria-hidden="true"></div>
        <div class="t2-track t2-track--head" style={`--t2-cols: ${cols};`}>
          {quarters.map((q, i) => (
            <div class:list={['t2-quarter', i === nowIdx ? 'is-now' : '']} style={`--c: ${i + 1}`}>
              {q}
              {i === nowIdx && <span class="t2-now-badge">NOW</span>}
            </div>
          ))}
        </div>
      </div>

      {streams.map((stream) => (
        <div class="t2-row">
          <div class="t2-label">
            <span class="t2-num">{stream.sub}</span>
            <span class="t2-name">{stream.name}</span>
          </div>
          <div class="t2-track" style={`--t2-cols: ${cols};`}>
            {nowIdx !== undefined && (
              <div class="t2-now-line" style={`--c: ${nowIdx + 1}`}></div>
            )}
            {stream.bars.map((b, bi) => {
              const span = Math.max(0.0001, b.e - b.s);
              const activeUntil = b.activeUntil ?? b.e;
              const activePct = Math.max(0, Math.min(100, ((activeUntil - b.s) / span) * 100));
              const kind = b.kind ?? 'primary';
              return (
                <button
                  type="button"
                  class:list={['t2-bar', `t2-bar--${kind}`]}
                  style={`--s: ${b.s}; --e: ${b.e}; --active-pct: ${activePct}%;`}
                  data-stream={stream.name}
                  data-headline={b.label}
                  data-panel-title={b.panelTitle ?? null}
                  data-panel-duration={b.panelDuration ?? b.duration ?? null}
                  data-description={b.title ?? ''}
                  data-default-active={bi === 0 && stream === streams[0] ? '1' : null}
                >
                  <span class="t2-bar-text">
                    <span class="t2-bar-label">{b.label}</span>
                    {b.duration && <span class="t2-bar-duration">{b.duration}</span>}
                  </span>
                </button>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <div class="t2-detail" data-t2-detail aria-live="polite">
      <div class="t2-detail-left">
        <div class="t2-detail-top">
          <div class="t2-detail-headline" role="heading" aria-level="3"></div>
          <div class="t2-detail-duration"></div>
        </div>
        <div class="t2-detail-stream"></div>
      </div>
      <div class="t2-detail-right">
        <p class="t2-detail-desc"></p>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  function initT2() {
    document.querySelectorAll('.t2-frame:not([data-t2-init])').forEach((frame) => {
      frame.setAttribute('data-t2-init', '1');
      const bars = Array.from(frame.querySelectorAll('.t2-bar'));
      const detail = frame.querySelector('[data-t2-detail]');
      if (!bars.length || !detail) return;
      const elStream = detail.querySelector('.t2-detail-stream');
      const elHead = detail.querySelector('.t2-detail-headline');
      const elDuration = detail.querySelector('.t2-detail-duration');
      const elDesc = detail.querySelector('.t2-detail-desc');

      function activate(bar) {
        bars.forEach((b) => b.classList.toggle('is-active', b === bar));
        elStream.textContent = bar.dataset.stream || '';
        const explicitTitle = bar.dataset.panelTitle;
        const explicitDuration = bar.dataset.panelDuration;
        const raw = bar.dataset.headline || '';
        elHead.textContent = explicitTitle || raw;
        elDuration.textContent = explicitDuration || '';
        elDesc.textContent = bar.dataset.description || '';
      }

      bars.forEach((bar) => bar.addEventListener('click', () => activate(bar)));
      const fallback = bars.find((b) => b.dataset.defaultActive === '1') || bars[0];
      if (fallback) activate(fallback);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initT2, { once: true });
  } else {
    initT2();
  }
</script>
