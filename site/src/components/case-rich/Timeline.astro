---
/**
 * Timeline — Gantt-style multi-stream roadmap. Markup lifted 1:1 from the
 * legacy cs01 case-page. CSS lives in legacy.css (.am-tl-*); this just
 * accepts streams data and renders the rows + bars.
 *
 * Usage in MDX:
 *   <Timeline
 *     stamp="// timeline · Q1 2024 → Q4 2025 · 8 streams"
 *     quarters={['Q1 24','Q2 24','Q3 24','Q4 24','Q1 25','Q2 25','Q3 25','Q4 25']}
 *     nowIdx={7}
 *     streams={[
 *       { name: 'Онбординг и аудит', sub: '01', bars: [{ kind: 'product', s: 1, e: 1, label: 'Аудит' }] },
 *       …
 *     ]}
 *   />
 */
interface Bar {
  kind: 'primary' | 'product' | 'bg' | 'short';
  s: number;
  e: number;
  label: string;
  title?: string;
  description?: string;
  /** 1-indexed lane within the stream row. Use to stack overlapping bars
   *  vertically (e.g. parallel sub-projects). Default: 1. */
  lane?: number;
}

interface Stream {
  name: string;
  sub: string;
  bars: Bar[];
}

interface Props {
  stamp?: string;
  quarters: string[];
  nowIdx?: number;
  streams: Stream[];
}

const { stamp, quarters, nowIdx, streams } = Astro.props;
const cols = quarters.length;

// Compute the period label for a bar from the quarters array.
// s/e are fractional column-line indices: s=1.0 starts col 1, e=2.0 ends
// col 1 (= starts col 2). Convert to a list of quarter labels the bar
// visually spans, then join into a "Q1 25 — Q3 25" range.
function periodFor(s: number, e: number): string {
  const startCol = Math.max(1, Math.floor(s));
  const endCol = Math.max(startCol, Math.ceil(e - 0.001));
  const a = quarters[startCol - 1];
  const b = quarters[endCol - 1];
  if (!a) return '';
  if (a === b || !b) return a;
  return `${a} — ${b}`;
}
---

<div class="cp-fullbleed am-tl-bleed">
  <div class="am-tl-frame">
    <div class="am-tl-headstrip">
      {stamp && <div class="am-tl-stamp" set:html={stamp} />}
      <div class="am-tl-legend">
        <span class="am-tl-legend-item"><i class="am-tl-sw am-tl-sw--primary"></i> Основное направление</span>
        <span class="am-tl-legend-item"><i class="am-tl-sw am-tl-sw--product"></i> Работа над продуктом</span>
        <span class="am-tl-legend-item"><i class="am-tl-sw am-tl-sw--bg"></i> Идёт фоном</span>
        <span class="am-tl-legend-item"><i class="am-tl-sw am-tl-sw--short"></i> Короткий проект</span>
      </div>
    </div>

    <div class="am-tl-grid" style={`--am-tl-cols: ${cols};`} data-am-tl>
      <div class="am-tl-row am-tl-row--head">
        <div class="am-tl-label" aria-hidden="true"></div>
        <div class="am-tl-track">
          {
            quarters.map((q, i) => (
              <div class:list={['am-tl-quarter', i === nowIdx ? 'is-now' : '']} style={`--c: ${i + 1}`}>
                {q}
                {i === nowIdx && <span class="am-tl-now">NOW</span>}
              </div>
            ))
          }
        </div>
      </div>

      {
        streams.map((stream, i) => {
          const maxLane = Math.max(1, ...stream.bars.map((b) => b.lane ?? 1));
          return (
            <div class="am-tl-row" style={`--am-tl-delay: ${(i + 1) * 60}ms;`}>
              <div class="am-tl-label">
                <span class="am-tl-dot"></span>
                <span class="am-tl-name">{stream.name}</span>
                <span class="am-tl-sub">{stream.sub}</span>
              </div>
              <div class="am-tl-track" style={`--am-tl-max-lane: ${maxLane};`}>
                {stream.bars.map((b, bi) => (
                  <button
                    type="button"
                    class:list={['am-tl-bar', `am-tl-bar--${b.kind}`]}
                    style={`--s: ${b.s}; --e: ${b.e}; --lane: ${b.lane ?? 1};`}
                    data-stream={stream.name}
                    data-period={periodFor(b.s, b.e)}
                    data-headline={b.label}
                    data-description={b.description ?? b.title ?? ''}
                    data-default-active={i === 0 && bi === 0 ? '1' : null}
                  >
                    {b.label}
                  </button>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="am-tl-detail" data-am-tl-detail aria-live="polite">
      <div class="am-tl-detail-meta">
        <span class="am-tl-detail-stream"></span>
        <span class="am-tl-detail-period"></span>
      </div>
      <h3 class="am-tl-detail-headline"></h3>
      <p class="am-tl-detail-desc"></p>
    </div>
  </div>
</div>

<script is:inline>
  function initAmTimeline() {
    document.querySelectorAll('.am-tl-frame:not([data-am-tl-init])').forEach((frame) => {
      frame.setAttribute('data-am-tl-init', '1');
      const bars = Array.from(frame.querySelectorAll('.am-tl-bar'));
      const detail = frame.querySelector('[data-am-tl-detail]');
      if (!bars.length || !detail) return;
      const elStream = detail.querySelector('.am-tl-detail-stream');
      const elPeriod = detail.querySelector('.am-tl-detail-period');
      const elHead = detail.querySelector('.am-tl-detail-headline');
      const elDesc = detail.querySelector('.am-tl-detail-desc');

      function activate(bar) {
        bars.forEach((b) => b.classList.toggle('is-active', b === bar));
        elStream.textContent = bar.dataset.stream || '';
        elPeriod.textContent = bar.dataset.period || '';
        elHead.textContent = bar.dataset.headline || '';
        elDesc.textContent = bar.dataset.description || '';
      }

      bars.forEach((bar) => {
        bar.addEventListener('click', () => activate(bar));
      });

      const fallback = bars.find((b) => b.dataset.defaultActive === '1') || bars[0];
      if (fallback) activate(fallback);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAmTimeline, { once: true });
  } else {
    initAmTimeline();
  }
</script>
