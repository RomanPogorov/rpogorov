---
/**
 * Row2 — two images side-by-side, each with its own caption. Mobile
 * collapses to single column. Renders inside `.dc-grid-2` (legacy
 * 2-column grid). Each image is a `.dc-figure` so the lightbox handler
 * picks it up.
 *
 * Usage in MDX:
 *   <Row2 items={[
 *     { src: '/.../a.png', alt: 'A', caption: '// option A' },
 *     { src: '/.../b.png', alt: 'B', caption: '// option B' },
 *   ]} portrait />
 */
type Item = { src: string; alt?: string; caption?: string; kind?: 'image' | 'video'; poster?: string };
interface Props {
  items: Item[];
  portrait?: boolean;
}
const { items, portrait = false } = Astro.props;
const figClass = portrait ? 'dc-figure dc-figure-portrait' : 'dc-figure';
---
<div class="dc-grid-2">
  {items.map((it) => (
    <figure class={figClass} data-media data-kind={it.kind ?? 'image'} data-src={it.src} data-caption={it.caption ?? ''}>
      {it.kind === 'video' ? (
        <video src={it.src} poster={it.poster} autoplay muted loop playsinline preload="metadata"></video>
      ) : (
        <img src={it.src} alt={it.alt ?? ''} />
      )}
      {it.caption && <figcaption>{it.caption}</figcaption>}
    </figure>
  ))}
</div>
