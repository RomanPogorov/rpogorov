---
/**
 * CpTimeline — sticky case-page section nav (legacy `<nav class="cp-timeline">`).
 *
 * Renders a vertical numbered list of section anchors. Inline JS hooks:
 * click → smooth scroll to `#${target}`; IntersectionObserver flips the
 * active class as the user scrolls through the case sections.
 *
 * Usage in MDX:
 *   <CpTimeline items={[
 *     { target: 'sec-01', num: '01', name: 'Контекст' },
 *     …
 *   ]} />
 */
interface Item {
  target: string;
  num: string;
  name: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<nav class="cp-timeline" aria-label="Case timeline">
  <ol class="cp-timeline-list">
    {
      items.map((it, i) => (
        <li>
          <button
            class:list={['cp-tl-item', i === 0 ? 'active' : '']}
            data-target={it.target}
            type="button"
          >
            <span class="cp-tl-num">{it.num}</span>
            <span class="cp-tl-name">{it.name}</span>
          </button>
        </li>
      ))
    }
  </ol>
</nav>

<script is:inline>
  // Defer to DOMContentLoaded so anchors `<a id="sec-NN">` rendered later
  // in the MDX body are present before we look them up. Without this the
  // script runs immediately after the <nav> tag and getElementById returns
  // null for every section, so click handlers never bind.
  function initCpTimeline() {
  document.querySelectorAll('.cp-timeline:not([data-cp-tl-init])').forEach((nav) => {
    nav.setAttribute('data-cp-tl-init', '1');
    const items = Array.from(nav.querySelectorAll('.cp-tl-item'));
    const targetMap = new Map();
    items.forEach((btn) => {
      const id = btn.dataset.target;
      const el = id ? document.getElementById(id) : null;
      if (el) targetMap.set(el, btn);
    });
    if ('IntersectionObserver' in window && targetMap.size) {
      // Find nearest scrolling ancestor — inside the case-page overlay,
      // it's the .case-page itself (scrolls), not the viewport.
      function findScrollRoot(el) {
        let p = el?.parentElement;
        while (p && p !== document.body) {
          const cs = getComputedStyle(p);
          if (
            (cs.overflowY === 'auto' || cs.overflowY === 'scroll') &&
            p.scrollHeight > p.clientHeight
          ) {
            return p;
          }
          p = p.parentElement;
        }
        return null;
      }
      const root = findScrollRoot(items[0]);
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const btn = targetMap.get(entry.target);
            if (!btn) return;
            if (entry.isIntersecting && entry.intersectionRatio > 0.3) {
              items.forEach((b) => b.classList.toggle('active', b === btn));
            }
          });
        },
        { threshold: [0.3, 0.6], root }
      );
      targetMap.forEach((_, el) => io.observe(el));
    }
    // Click handler must scroll inside the same scroll root so the IO sees it
    items.forEach((btn) => {
      const id = btn.dataset.target;
      const el = id ? document.getElementById(id) : null;
      if (!el) return;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        // override default smooth scroll if scroll root is non-window
        const root = (function findRoot(node) {
          let p = node?.parentElement;
          while (p && p !== document.body) {
            const cs = getComputedStyle(p);
            if ((cs.overflowY === 'auto' || cs.overflowY === 'scroll') && p.scrollHeight > p.clientHeight) return p;
            p = p.parentElement;
          }
          return null;
        })(el);
        if (root) {
          const target = el.getBoundingClientRect().top - root.getBoundingClientRect().top + root.scrollTop - 24;
          root.scrollTo({ top: target, behavior: 'smooth' });
        } else {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCpTimeline, { once: true });
  } else {
    initCpTimeline();
  }
</script>
