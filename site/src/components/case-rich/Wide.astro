---
/**
 * Wide — full-width landscape image with caption. Wraps in
 * legacy `.dc-figure` so it sits inside the case body column.
 */
interface Props {
  src: string;
  alt?: string;
  caption?: string;
}
const { src, alt = '', caption } = Astro.props;
const cleanCaption = caption?.replace(/^\s*\/\/\s*/, '');
---
<figure class="dc-figure" data-media data-kind="image" data-src={src} data-caption={cleanCaption ?? ''}>
  <img src={src} alt={alt} />
  {cleanCaption && <figcaption>{cleanCaption}</figcaption>}
</figure>
