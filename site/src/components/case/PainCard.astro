---
/**
 * Pain card — a callout for "biz problem", "user pain", a numbered insight,
 * etc. Renders as a card with a left accent bar, an Inter eyebrow tag,
 * a title, and a body paragraph.
 */
interface Props {
  tag?: string;
  title: string;
}
const { tag, title } = Astro.props;
---

<article class="pain">
  {tag && <span class="tag">{tag}</span>}
  <h4 class="title">{title}</h4>
  <p class="body">
    <slot />
  </p>
</article>

<style>
  .pain {
    background: var(--surface-card);
    border: 1px solid var(--border-card);
    border-left: 3px solid var(--acc);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .tag {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 700;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--acc);
  }
  .title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text-strong);
    margin: 0;
  }
  .body {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0;
  }
</style>
