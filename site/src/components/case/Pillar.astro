---
/**
 * Solution pillar — small card with a numbered/named eyebrow and a body
 * paragraph. Used in the "solution breakdown" row, typically 3–4 across.
 */
interface Props {
  num: string;
  label: string;
}
const { num, label } = Astro.props;
---

<article class="pillar">
  <header class="eyebrow">
    <span class="num">{num}</span>
    <span class="sep">/</span>
    <span class="label">{label}</span>
  </header>
  <p class="body">
    <slot />
  </p>
</article>

<style>
  .pillar {
    background: var(--surface-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .eyebrow {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    font-weight: 700;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--acc);
  }
  .sep {
    opacity: 0.55;
  }
  .body {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--text-base);
  }
</style>
